#include <WiFi.h>
#include <WiFiUdp.h>
#include <Wire.h>

const char* ssid = "POCO X3 Pro";
const char* password = "12345678";

WiFiUDP udp;
const uint16_t DATA_PORT = 5005;

WiFiUDP cmdUdp;
const uint16_t CMD_PORT = 5006;

#define ADXL_ADDR 0x53
#define REG_DEVID        0x00
#define REG_POWER_CTL    0x2D
#define REG_DATA_FORMAT  0x31
#define REG_BW_RATE      0x2C
#define REG_DATAX0       0x32

#define EEG_CH1 4
#define EEG_CH2 5
#define EEG_CH3 6
#define EEG_CH4 7

const float VREF = 3.3;        // ولتاژ مرجع ADC ESP32
const int GAIN = 1000;         // گین پری‌امپ
const int ADC_BASELINE = 1860; // baseline ADC برای 1.5V

const uint32_t SAMPLE_PERIOD_MS = 10; // 100Hz
uint32_t lastSampleTime = 0;

bool samplingEnabled = false;

// I2C helpers
void i2cWrite(uint8_t reg, uint8_t data) {
  Wire.beginTransmission(ADXL_ADDR);
  Wire.write(reg);
  Wire.write(data);
  Wire.endTransmission();
}

bool i2cRead(uint8_t reg, uint8_t* buf, uint8_t len) {
  Wire.beginTransmission(ADXL_ADDR);
  Wire.write(reg);
  if(Wire.endTransmission(false) != 0) return false;
  Wire.requestFrom(ADXL_ADDR, len);
  for (uint8_t i = 0; i < len; i++) {
    if(Wire.available()) buf[i] = Wire.read();
    else return false;
  }
  return true;
}

// ADC to µV 
int16_t adc2uV(int raw) {
  float v = (raw - ADC_BASELINE) / 4095.0 * VREF;
  return (int16_t)(v * 1e6 / GAIN);
}

void setup() {
  Serial.begin(115200);

  // I2C
  Wire.begin(16, 15);
  Wire.setClock(400000);

  // Check ADXL345
  uint8_t devid;
  if(!i2cRead(REG_DEVID, &devid, 1) || devid != 0xE5) {
    Serial.println("ADXL345 not found!");
    while(1);
  }

  // ADXL345 config
  i2cWrite(REG_POWER_CTL, 0x00); // standby
  i2cWrite(REG_BW_RATE, 0x0A);   // 100Hz
  i2cWrite(REG_DATA_FORMAT, 0x08); // full res ±2g
  i2cWrite(REG_POWER_CTL, 0x08); // measurement mode

  // WiFi
  WiFi.begin(ssid, password);
  while (WiFi.status() != WL_CONNECTED) {
    delay(500);
    Serial.print(".");
  }
  Serial.println("\nWiFi connected");
  Serial.print("ESP IP: "); Serial.println(WiFi.localIP());
  Serial.print("Broadcast IP: "); Serial.println(WiFi.broadcastIP());

  // UDP
  udp.begin(DATA_PORT);
  cmdUdp.begin(CMD_PORT);
  Serial.printf("Command listener started on port %d\n", CMD_PORT);
}

void loop() {
  int packetSize = cmdUdp.parsePacket();
  if (packetSize) {
    char cmd[10];
    int len = cmdUdp.read(cmd, 9);
    cmd[len] = 0;

    if (strcmp(cmd, "START") == 0) {
      samplingEnabled = true;
      Serial.println("Sampling STARTED");
    } else if (strcmp(cmd, "STOP") == 0) {
      samplingEnabled = false;
      Serial.println("Sampling STOPPED");
    }
  }

  uint32_t now = millis();
  if (samplingEnabled && (now - lastSampleTime >= SAMPLE_PERIOD_MS)) {
    lastSampleTime = now;

    int16_t eeg[4];
    eeg[0] = adc2uV(analogRead(EEG_CH1));
    eeg[1] = adc2uV(analogRead(EEG_CH2));
    eeg[2] = adc2uV(analogRead(EEG_CH3));
    eeg[3] = adc2uV(analogRead(EEG_CH4));

    uint8_t raw[6];
    int16_t ax=0, ay=0, az=0;
    if(i2cRead(REG_DATAX0, raw, 6)) {
      ax = (raw[1]<<8) | raw[0];
      ay = (raw[3]<<8) | raw[2];
      az = (raw[5]<<8) | raw[4];
    }

    uint8_t packet[16];
    packet[0] = 0xAA;
    packet[1] = 0x55;

    for(int i=0; i<4; i++){
      packet[2+i*2] = eeg[i] & 0xFF;
      packet[3+i*2] = eeg[i] >> 8;
    }

    packet[10] = ax & 0xFF;
    packet[11] = ax >> 8;
    packet[12] = ay & 0xFF;
    packet[13] = ay >> 8;
    packet[14] = az & 0xFF;
    packet[15] = az >> 8;

    IPAddress bcast = WiFi.broadcastIP();
    udp.beginPacket(bcast, DATA_PORT);
    udp.write(packet, sizeof(packet));
    udp.endPacket();

    Serial.printf("EEG[uV]: %d %d %d %d | IMU: %d %d %d\n",
                  eeg[0], eeg[1], eeg[2], eeg[3], ax, ay, az);
  }
}
